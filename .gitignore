.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Loglar
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / editör
.idea/
*.swp
*.swo

# Geçici
.temp
.tmp
*.local
